{
  "name": "pi-slack-bot",
  "version": "0.1.0",
  "description": "Slack bot exposing pi as a conversational coding agent",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node --import tsx/esm src/index.ts",
    "test": "find src -name '*.test.ts' | xargs node --import tsx/esm --test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "audit": "npm audit --omit=dev || true",
    "coverage": "find src -name '*.test.ts' | xargs node --import tsx/esm --test --experimental-test-coverage",
    "duplication": "npx -y jscpd --min-lines 10 --min-tokens 50 --threshold 5 src/"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.55.4",
    "@slack/bolt": "^4.6.0",
    "dotenv": "^16.4.7",
    "slackify-markdown": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
